# ============================================
# NLP Thesis Project – Production .gitignore
# ============================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
wheels/
*.whl

# ---- Virtual Environments ----
.venv/
venv/
ENV/

# ---- HuggingFace Cache ----
hf_cache/

# ---- Data (all stages) ----
data/raw/
data/interim/
data/processed/
data/training/
data/external/
!data/**/.gitkeep

# ---- Model Weights & Checkpoints ----
models/
!models/.gitkeep
*.pt
*.pth
*.safetensors
*.bin
*.ckpt
best_roberta.zip
tmp_trainer/

# ---- Reports (generated outputs) ----
reports/figures/
reports/logs/
!reports/**/.gitkeep

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- OS Artifacts ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
reports/*.log

